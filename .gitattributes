# Auto detect text files and perform LF normalization
* text=auto

# ============================================
# 敏感信息保护 - 防止泄漏
# ============================================

# 确保敏感文件不会被意外提交
.env* filter=git-crypt diff=git-crypt
*.key filter=git-crypt diff=git-crypt
*.pem filter=git-crypt diff=git-crypt
*.p12 filter=git-crypt diff=git-crypt
*.jks filter=git-crypt diff=git-crypt
*.keystore filter=git-crypt diff=git-crypt
*.truststore filter=git-crypt diff=git-crypt

# 配置文件处理
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf

# 源代码文件
*.java text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf

# 二进制文件
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar.gz binary
*.rar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.so binary
*.dll binary
*.exe binary

# 确保敏感配置文件使用 LF 换行符
**/application-local.yml text eol=lf
**/application-secret.yml text eol=lf
**/application-private.yml text eol=lf
