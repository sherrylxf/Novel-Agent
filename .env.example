# ============================================
# 环境变量配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写真实的配置值
# 3. 确保 .env 文件已被 .gitignore 忽略
# ============================================

# LLM API配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com

# MySQL数据库配置
SPRING_DATASOURCE_MYSQL_URL=jdbc:mysql://127.0.0.1:3306/novel_agent?useUnicode=true&characterEncoding=utf8&autoReconnect=true&zeroDateTimeBehavior=convertToNull&serverTimezone=UTC&useSSL=false
SPRING_DATASOURCE_MYSQL_USERNAME=root
SPRING_DATASOURCE_MYSQL_PASSWORD=your-mysql-password

# PostgreSQL向量数据库配置
SPRING_DATASOURCE_PGVECTOR_URL=jdbc:postgresql://127.0.0.1:5432/novel_vector
SPRING_DATASOURCE_PGVECTOR_USERNAME=postgres
SPRING_DATASOURCE_PGVECTOR_PASSWORD=your-postgres-password

# Neo4j知识图谱配置
SPRING_NEO4J_URI=bolt://localhost:7687
SPRING_NEO4J_AUTHENTICATION_USERNAME=neo4j
SPRING_NEO4J_AUTHENTICATION_PASSWORD=your-neo4j-password
